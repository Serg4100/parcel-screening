{
  "manifest_version": 3,
  "name": "Parcel Screen — Preliminary Site Triage",
  "version": "0.1.0",
  "description": "Go/caution/no-go parcel screening for San Jose, CA: zoning, buildability, FEMA flood, seismic, geologic, slope & soil.",
  "permissions": ["storage", "sidePanel", "contextMenus"],
  "host_permissions": [
    "https://geo.sanjoseca.gov/*",
    "https://hazards.fema.gov/*",
    "https://gis.conservation.ca.gov/*",
    "https://geocoding.geo.census.gov/*",
    "https://services2.arcgis.com/tcv2cMrq63AgvbHF/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.sccassessor.org/*",
        "https://asr.santaclaracounty.gov/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Parcel Screen",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'; frame-ancestors 'none'"
  }
}
